{
  "actorOutputSchemaVersion": 1,
  "title": "EUIPO Trademark Search output",
  "description": "Links to the dataset items and run summary generated by the actor.",
  "type": "object",
  "properties": {
    "results": {
      "type": "string",
      "title": "Matching trademarks",
      "template": "{{links.apiDefaultDatasetUrl}}/items"
    },
    "summary": {
      "type": "string",
      "title": "Run summary",
      "template": "{{links.apiDefaultKeyValueStoreUrl}}/records/OUTPUT_SUMMARY"
    }
  }
}
