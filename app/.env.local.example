# ─────────────────────────────────────────────────────────────────────────────
# DoppelSpotter — App Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Firebase (Client SDK — safe to expose publicly) ─────────────────────────
# Found in Firebase Console > Project Settings > Your apps > Web app > Config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin SDK (Server-side only — keep secret) ─────────────────────
# Paste the entire service account JSON as a single line (escaped).
# Generated in Firebase Console > Project Settings > Service Accounts > Generate new private key
# In production (Cloud Run), this is injected via Secret Manager (see cloudbuild.yaml).
FIREBASE_SERVICE_ACCOUNT_KEY=

# ─── Apify ───────────────────────────────────────────────────────────────────
# Your Apify API token — https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# Shared secret used to validate incoming Apify webhook callbacks.
# Set any strong random string here and use the same value when configuring
# webhooks in the Apify console or via the API.
APIFY_WEBHOOK_SECRET=

# WhoisXML Brand Alert API key (required for doppelspotter/whoisxml-brand-alert)
# https://brand-alert.whoisxmlapi.com/api
WHOISXML_API_KEY=

# ─── OpenRouter ──────────────────────────────────────────────────────────────
# Your OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# LLM model to use for analysis (default: anthropic/claude-3.5-haiku)
# Browse available models at https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# ─── App URL ─────────────────────────────────────────────────────────────────
# The public base URL of this app. Used to construct webhook callback URLs sent
# to Apify when starting actor runs. Apify must be able to reach this URL.
#
# Local dev: use an ngrok tunnel (see docs/PIPELINE_SETUP.md)
#   ngrok http 3000  →  copy the HTTPS forwarding URL here
#
# Production (Cloud Run): set to the Cloud Run service URL, e.g.:
#   https://doppelspotter-app-xxxxxxxxxx-ew.a.run.app
APP_URL=
